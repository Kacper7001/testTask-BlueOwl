{% doc %}
  @prompt
    Napisz sekcje, która będzie "Ready fit" rzeczy które do siebie pasują - ubran, akcesorii
    Dodaj wiele fajnych ustawien

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ready-fit-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-ready-fit-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-ready-fit-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-ready-fit-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin }}px 0;
    font-weight: {{ block.settings.title_weight }};
  }

  .ai-ready-fit-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    max-width: 600px;
    {% if block.settings.text_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% endif %}
  }

  .ai-ready-fit-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.content_spacing }}px;
  }

  .ai-ready-fit-set-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};box-shadow: {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_spread }}px {{ block.settings.card_shadow_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-ready-fit-set-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: {{ block.settings.card_shadow_blur | times: 1.5 }}px {{ block.settings.card_shadow_blur | times: 1.5 }}px {{ block.settings.card_shadow_spread | times: 2 }}px {{ block.settings.card_shadow_color }};
  }

  .ai-ready-fit-set-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.set_title_size }}px;
    color: {{ block.settings.set_title_color }};
    margin: 0 0 {{ block.settings.set_title_margin }}px 0;
    font-weight: {{ block.settings.set_title_weight }};
  }

  .ai-ready-fit-products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.product_gap }}px;
    margin-bottom: {{ block.settings.products_margin }}px;
  }

  .ai-ready-fit-product-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-ready-fit-product-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    border-radius: {{ block.settings.product_image_radius }}px;
    overflow: hidden;
    margin-bottom: 8px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ready-fit-product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-ready-fit-product-image-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-ready-fit-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 4px 0;
    font-weight: {{ block.settings.product_title_weight }};
  }

  .ai-ready-fit-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
    margin: 0;
    font-weight: {{ block.settings.product_price_weight }};
  }

  .ai-ready-fit-total-section-{{ ai_gen_id }} {
    border-top: {{ block.settings.total_border_width }}px solid {{ block.settings.total_border_color }};
    padding-top: {{ block.settings.total_padding }}px;
    margin-top: {{ block.settings.total_margin }}px;
  }

  .ai-ready-fit-total-row-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .ai-ready-fit-total-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.total_label_size }}px;
    color: {{ block.settings.total_label_color }};
    font-weight: {{ block.settings.total_label_weight }};
  }

  .ai-ready-fit-total-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.total_price_size }}px;
    color: {{ block.settings.total_price_color }};
    font-weight: {{ block.settings.total_price_weight }};
  }

  .ai-ready-fit-discount-{{ ai_gen_id }} {
    color: {{ block.settings.discount_color }};
  }

  .ai-ready-fit-final-total-{{ ai_gen_id }} {
    font-size: {{ block.settings.final_total_size }}px;
    color: {{ block.settings.final_total_color }};
    font-weight: {{ block.settings.final_total_weight }};
    border-top: 1px solid {{ block.settings.total_border_color }};
    padding-top: 8px;
    margin-top: 8px;
  }

  .ai-ready-fit-button-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    margin-top: {{ block.settings.button_margin }}px;
  }

  .ai-ready-fit-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text }};
    border-color: {{ block.settings.button_hover_border }};
  }

  .ai-ready-fit-savings-badge-{{ ai_gen_id }} {
    background-color: {{ block.settings.savings_badge_background }};
    color: {{ block.settings.savings_badge_text }};
    padding: 4px 8px;
    border-radius: {{ block.settings.savings_badge_radius }}px;
    font-size: {{ block.settings.savings_badge_size }}px;
    font-weight: {{ block.settings.savings_badge_weight }};display: inline-block;
    margin-bottom: 8px;
  }

  @media screen and (max-width: 768px) {
    .ai-ready-fit-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-ready-fit-products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }

    .ai-ready-fit-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-ready-fit-set-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-ready-fit-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ready-fit-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.description != blank %}
      <div class="ai-ready-fit-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-ready-fit-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-ready-fit-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-ready-fit-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign set_title_key = 'set_' | append: i | append: '_title'
          assign product_1_key = 'set_' | append: i | append: '_product_1'
          assign product_2_key = 'set_' | append: i | append: '_product_2'
          assign product_3_key = 'set_' | append: i | append: '_product_3'
          assign product_4_key = 'set_' | append: i | append: '_product_4'

          assign set_title = block.settings[set_title_key]
          assign product_1 = block.settings[product_1_key]
          assign product_2 = block.settings[product_2_key]
          assign product_3 = block.settings[product_3_key]
          assign product_4 = block.settings[product_4_key]

          assign has_products = false
          if product_1 != blank or product_2 != blank or product_3 != blank or product_4 != blank
            assign has_products = true
          endif
        %}

        {% if has_products or set_title != blank %}
          <div class="ai-ready-fit-set-{{ ai_gen_id }}">
            {% if set_title != blank %}
              <h3 class="ai-ready-fit-set-title-{{ ai_gen_id }}">{{ set_title }}</h3>
            {% endif %}<div class="ai-ready-fit-products-{{ ai_gen_id }}">
              {% assign products = product_1 | append: ',' | append: product_2 | append: ',' | append: product_3 | append: ',' | append: product_4 | split: ',' %}
              {% assign total_price = 0 %}
              
              {% for product_handle in products %}
                {% if product_handle != blank %}
                  {% case forloop.index %}
                    {% when 1 %}
                      {% assign current_product = product_1 %}
                    {% when 2 %}
                      {% assign current_product = product_2 %}
                    {% when 3 %}
                      {% assign current_product = product_3 %}
                    {% when 4 %}
                      {% assign current_product = product_4 %}
                  {% endcase %}

                  {% if current_product != blank %}
                    {% assign total_price = total_price | plus: current_product.price %}<div class="ai-ready-fit-product-{{ ai_gen_id }}">
                      <div class="ai-ready-fit-product-image-{{ ai_gen_id }}">
                        {% if current_product.featured_image %}
                          <img
                            src="{{ current_product.featured_image | image_url: width: 300}}"
                            alt="{{ current_product.featured_image.alt | escape }}"
                            loading="lazy"
                            width="300"
                            height="300"
                          >
                        {% else %}
                          {{ 'product-apparel-1' | placeholder_svg_tag }}
                        {% endif %}
                      </div>
                      <h4 class="ai-ready-fit-product-title-{{ ai_gen_id }}">{{ current_product.title }}</h4>
                      <div class="ai-ready-fit-product-price-{{ ai_gen_id }}">{{ current_product.price | money }}</div>
                    </div>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>

            {% if total_price > 0 %}
              <div class="ai-ready-fit-total-section-{{ ai_gen_id }}">
                {% if block.settings.show_savings_badge and block.settings.discount_percentage > 0 %}
                  <div class="ai-ready-fit-savings-badge-{{ ai_gen_id }}">Oszczędzasz {{ block.settings.discount_percentage }}%!
                  </div>
                {% endif %}

                <div class="ai-ready-fit-total-row-{{ ai_gen_id }}">
                  <span class="ai-ready-fit-total-label-{{ ai_gen_id }}">Cena regularna:</span>
                  <span class="ai-ready-fit-total-price-{{ ai_gen_id }}">{{ total_price | money }}</span>
                </div>

                {% if block.settings.discount_percentage > 0 %}
                  {% assign discount_amount = total_price | times: block.settings.discount_percentage | divided_by: 100 %}
                  {% assign discounted_total = total_price | minus: discount_amount %}
                  <div class="ai-ready-fit-total-row-{{ ai_gen_id }}">
                    <span class="ai-ready-fit-total-label-{{ ai_gen_id }}">Zniżka ({{ block.settings.discount_percentage }}%):</span>
                    <span class="ai-ready-fit-total-price-{{ ai_gen_id }} ai-ready-fit-discount-{{ ai_gen_id }}">-{{ discount_amount | money }}</span>
                  </div>

                  <div class="ai-ready-fit-total-row-{{ ai_gen_id }} ai-ready-fit-final-total-{{ ai_gen_id }}">
                    <span class="ai-ready-fit-total-label-{{ ai_gen_id }}">Cena zestawu:</span>
                    <span class="ai-ready-fit-total-price-{{ ai_gen_id }}">{{ discounted_total | money }}</span>
                  </div>
                {% else %}
                  <div class="ai-ready-fit-total-row-{{ ai_gen_id }} ai-ready-fit-final-total-{{ ai_gen_id }}">
                    <span class="ai-ready-fit-total-label-{{ ai_gen_id }}">Cena zestawu:</span>
                    <span class="ai-ready-fit-total-price-{{ ai_gen_id }}">{{ total_price | money }}</span>
                  </div>
                {% endif %}

                {% if block.settings.button_text != blank %}
                  <a href="{{ block.settings.button_link }}" class="ai-ready-fit-button-{{ ai_gen_id }}">
                    {{ block.settings.button_text }}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

